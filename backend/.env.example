UPLOAD_DIR=./storage/uploads
SNAPSHOT_DIR=./storage/snapshots
API_STORE_PATH=./storage/apis.json
JOB_STORE_PATH=./storage/jobs.json
SEED_INDEX_PATH=./api_index.json
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# LLM agent — natural-language query rewrite/expansion.
# Set to true and provide a key to enable; search gracefully falls back to
# rule-based retrieval when disabled or the LLM is unreachable.
ENABLE_LLM_AGENT=false
GEMINI_API_KEY=
GEMINI_BASE_URL=https://aicenter.thyseed.com/v1beta
GEMINI_MODEL=gemini-3.5-flash
LLM_TIMEOUT=20

# Local embedding / vector search (fastembed, offline ONNX model).
# Seed the model into EMBEDDING_CACHE_DIR, build vectors, then set true.
ENABLE_VECTOR_SEARCH=false
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_CACHE_DIR=./storage/models
VECTORS_PATH=./storage/vectors.npz
